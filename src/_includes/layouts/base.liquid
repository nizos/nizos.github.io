<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta http-equiv="Content-Security-Policy" content="default-src 'none'; script-src 'sha256-cfn9om7TXkbmZ82INL7n0QEnTDk6c9VVZAfrMmWQFaM='; style-src 'self'; img-src 'self'; media-src 'self'; connect-src 'self' https://plausible.io/api/event; manifest-src 'self';">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <link href="/assets/css/main.css" rel="stylesheet" />

        <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
        <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
        <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
        <link rel="manifest" href="/site.webmanifest">
        <link rel="alternate" type="application/atom+xml" title="{{ site.name }}" href="/feed.xml">

        {%- comment %} Machine-readable resource discovery for agents and LLMs {% endcomment %}
        <link rel="describedby" href="/llms.txt" type="text/markdown" title="Site index for LLMs">
        <link rel="sitemap" href="/sitemap.xml" type="application/xml">
        {%- if tags contains "posts" %}
        <link rel="alternate" type="text/markdown" href="/{{ title | slugify }}.md" title="{{ title | escape }} — Markdown source">
        {%- endif %}

        {% assign desc = description %}
        {% if desc == blank %}
            {% assign desc = site.description %}
        {% endif %}
        {% if desc %}
            <meta name="description" content="{{ desc | escape  }}">
            <meta property="og:description" content="{{ desc | escape }}">
            <meta name="description" content="{{ desc | escape }}"/>
        {% endif %}

        {% if socialImage == blank %}
            {% assign socialImage = site.defaultSocialImage %}
        {% endif %}
        {% if socialImage %}
            <meta property="og:image" content="{{ socialImage | escape }}"/>
            <meta name="twitter:image" content="{{ socialImage | escape }}"/>
        {% endif %}

        <title>
            {% if title == site.name %}
                {{ site.title | escape }}
            {% else %}
                {{ title | escape }} | {{ site.name | escape}}
            {% endif %}
        </title>

        <meta property="og:site_name" content="{{ site.name }}">
        <meta property="og:type" content="website">
        <script defer data-domain="nizar.se" src="/plausible.js" data-api="https://plausible.io/api/event" integrity="sha256-cfn9om7TXkbmZ82INL7n0QEnTDk6c9VVZAfrMmWQFaM=" crossorigin="anonymous"></script>

        {%- comment %} Structured data (JSON-LD) — typed facts for search engines and agents {% endcomment %}
        {%- capture authorLd %}{"@type":"Person","name":{{ site.authorFullName | jsonString }},"url":"{{ site.url }}/about/","jobTitle":"Software architect and consultant","sameAs":["https://github.com/nizos"]}{% endcapture %}
        {%- if tags contains "posts" %}
        <script type="application/ld+json">
        {
          "@context": "https://schema.org",
          "@type": "BlogPosting",
          "headline": {{ title | jsonString }},
          {%- if desc %}
          "description": {{ desc | jsonString }},
          {%- endif %}
          "datePublished": "{{ page.date | isoDate }}",
          "url": "{{ site.url }}{{ page.url }}",
          "mainEntityOfPage": { "@type": "WebPage", "@id": "{{ site.url }}{{ page.url }}" },
          {%- if socialImage %}
          "image": "{{ socialImage | prepend: site.url }}",
          {%- endif %}
          {%- assign keywords = tags | postTags | join: ", " %}
          {%- if keywords != "" %}
          "keywords": {{ keywords | jsonString }},
          {%- endif %}
          "inLanguage": "en",
          "author": {{ authorLd }},
          "publisher": {{ authorLd }},
          "isPartOf": { "@type": "Blog", "@id": "{{ site.url }}/#blog", "name": {{ site.name | jsonString }} }
        }
        </script>
        {%- elsif page.url == "/about/" %}
        <script type="application/ld+json">
        {
          "@context": "https://schema.org",
          "@type": "ProfilePage",
          "url": "{{ site.url }}/about/",
          "name": {{ title | jsonString }},
          "inLanguage": "en",
          "mainEntity": {{ authorLd }}
        }
        </script>
        {%- else %}
        <script type="application/ld+json">
        {
          "@context": "https://schema.org",
          "@type": "WebSite",
          "name": {{ site.name | jsonString }},
          "url": "{{ site.url }}",
          "description": {{ site.description | jsonString }},
          "inLanguage": "en",
          "author": {{ authorLd }},
          "publisher": {{ authorLd }}
        }
        </script>
        {%- endif %}
    </head>
    <body>
        <div class="layout-wrapper">
            {% include 'partials/header' %}
            <main class="main">
                {{ content }}
            </main>
            {% include 'partials/footer' %}
        </div>
    </body>
</html>